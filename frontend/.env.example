# FastAPI backend (server-only — never expose to the browser)
BACKEND_URL=http://127.0.0.1:8000

# Supabase — from the project's API settings (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# Note: SUPABASE_SECRET_KEY (service-role key) has moved to the backend .env.
# The frontend no longer writes directly to the questions pool — the backend does
# when DB_WRITE_ENABLED=1 is set there.
