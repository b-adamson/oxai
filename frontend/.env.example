# FastAPI backend (server-only — never expose to the browser)
BACKEND_URL=http://127.0.0.1:8000

# Supabase — from the project's API settings (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# Server-only. Bypasses row-level security — never NEXT_PUBLIC_, never commit.
SUPABASE_SECRET_KEY=<service-role-or-secret-key>
